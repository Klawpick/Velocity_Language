window("Velocity FPS Demo", 1280, 720)

player_x = 0
player_y = 0
player_z = -5

yaw = 0
pitch = 0

speed = 30

loop(1f)
{
    delta = dt()

    yaw = yaw + mouse_dx() * 0.002
    pitch = pitch + mouse_dy() * 0.002

    when (key_pressed("w"))
    {
        player_x = player_x + sin(yaw) * speed * delta
        player_z = player_z + cos(yaw) * speed * delta
    }

    when (key_pressed("s"))
    {
        player_x = player_x - sin(yaw) * speed * delta
        player_z = player_z - cos(yaw) * speed * delta
    }

    when (key_pressed("a"))
    {
        player_x = player_x - cos(yaw) * speed * delta
        player_z = player_z + sin(yaw) * speed * delta
    }

    when (key_pressed("d"))
    {
        player_x = player_x + cos(yaw) * speed * delta
        player_z = player_z - sin(yaw) * speed * delta
    }

    camera(player_x, player_y, player_z)
    camera_rotation(pitch, yaw)

    clear_screen()

    draw_cube(-20, 5, 20, 2, 0)
    draw_cube(-15, 5, 20, 2, 0)
    draw_cube(-10, 5, 20, 2, 0)
    draw_cube(-5, 5, 20, 2, 0)
    draw_cube(0, 5, 20, 2, 0)
    draw_cube(5, 5, 20, 2, 0)
    draw_cube(10, 5, 20, 2, 0)
    draw_cube(15, 5, 20, 2, 0)
    draw_cube(20, 5, 20, 2, 0)

    draw_cube(-20, 5, 25, 2, 0)
    draw_cube(-15, 5, 25, 2, 0)
    draw_cube(-10, 5, 25, 2, 0)
    draw_cube(-5, 5, 25, 2, 0)
    draw_cube(0, 5, 25, 2, 0)
    draw_cube(5, 5, 25, 2, 0)
    draw_cube(10, 5, 25, 2, 0)
    draw_cube(15, 5, 25, 2, 0)
    draw_cube(20, 5, 25, 2, 0)

    draw_text("Velocity FPS Demo", 20, 20)

    present()
}